{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "context": "./webapp"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "java -jar app.jar"
  },
  "env": {
    "DB_URL": {
      "description": "MySQL connection URL",
      "value": "jdbc:mysql://mysql:3306/take_a_break_web?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC"
    },
    "DB_USER": {
      "description": "Database user",
      "value": "takeabreak"
    },
    "DB_PASS": {
      "description": "Database password",
      "value": "Informatica_1706869"
    }
  },
  "services": [
    {
      "name": "mysql",
      "image": "mysql:8.0",
      "env": {
        "MYSQL_DATABASE": "take_a_break_web",
        "MYSQL_USER": "takeabreak",
        "MYSQL_PASSWORD": "Informatica_1706869",
        "MYSQL_ROOT_PASSWORD": "rootpass123"
      }
    }
  ]
}
