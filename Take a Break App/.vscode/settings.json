{
  "java.import.maven.enabled": true,
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.autobuild.enabled": true,
  "java.saveActions.organizeImports": false,
  "java.project.sourcePaths": ["src"],
  "java.project.outputPath": "bin",
  "java.project.referencedLibraries": ["dist/lib/**/*.jar"],
  "java.configuration.maven.globalSettings": "",
  "java.import.exclusions": [
    "src/RegistoFolgas/**",
    "**/node_modules/**",
    "**/.metadata/**",
    "**/archetype-resources/**",
    "**/META-INF/maven/**"
  ],
  "java.maven.downloadSources": true,
  "java.debug.settings.autoOpenDebugViews": false,
  "java.debug.settings.enableRunDebugCodeLens": false,
  "java.debug.settings.console": "integratedTerminal",
  "java.debug.settings.onBuildFailureProceed": false,
  "java.configuration.runtimes": [
    {
      "name": "JavaSE-24",
      "path": "C:\\Program Files\\Java\\jdk-24",
      "default": true
    }
  ],
  "[java]": {
    "editor.codeActionsOnSave": {}
  },
  "files.exclude": {
    "**/bin": true
  },
  "java.compile.nullAnalysis.mode": "automatic"
}
